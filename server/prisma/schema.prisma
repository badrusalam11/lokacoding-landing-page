generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  RESELLER
  ADMIN
}

enum ProjectStatus {
  PENDING
  REVIEWED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  phone        String?
  role         Role      @default(RESELLER)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  projects     Project[]
}

model Project {
  id                 String        @id @default(uuid())
  reseller           User          @relation(fields: [resellerId], references: [id])
  resellerId         String
  clientName         String
  clientContact      String
  description        String
  estimatedBudget    Int?
  status             ProjectStatus @default(PENDING)
  adminNote          String?
  developmentSummary String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([resellerId])
}
