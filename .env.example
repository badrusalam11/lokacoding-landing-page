RESELLER_DOMAIN=reseller.lokacoding.com

# Loopback-only host ports for api/web. Change these if they clash with
# ports already used by another project on the same VPS.
RESELLER_API_PORT=4010
RESELLER_WEB_PORT=3010

# Only needed with docker-compose.shared-proxy.yml (deploying alongside an
# existing reverse proxy on the same VPS). Set to that proxy's Docker
# network name — see README "Deploy ke Production — Skenario B".
# SHARED_PROXY_NETWORK=

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lokacoding_reseller

JWT_SECRET=change-me-to-a-long-random-string

ADMIN_EMAIL=admin@lokacoding.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Loka Coding Admin
